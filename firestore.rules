rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); 
    }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidAdmin(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string && data.email.size() <= 100;
    }

    function isValidSetting(data) {
      return data.keys().hasAll(['key', 'value']) &&
             data.key is string && data.key.size() <= 100 &&
             data.value is string && data.value.size() <= 1000;
    }

    // --- Match Blocks ---

    // Admins Collection: Only existing admins can add new admins. 
    // Initial bootstrapping usually handled by platform or manual entry.
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin() && isValidId(adminId) && isValidAdmin(incoming());
    }

    // Settings Collection: Public read, Admin write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingId) && isValidSetting(incoming());
    }
  }
}
